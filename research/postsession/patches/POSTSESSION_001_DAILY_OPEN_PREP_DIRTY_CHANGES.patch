+    def _expired_order_signal_blocks_same_bar_resubmit(
+        self,
+        signal: Signal,
+        metadata: dict[str, Any],
+        match: dict[str, Any],
+        *,
+        module: EntryModule,
+    ) -> bool:
+        """Keep reconciled paper auto-cancels idempotent for the same bar.
+
+        Expired shadow/no-order signals may be replaced later, but an expired
+        signal that already submitted an IBKR paper order represents an
+        economic attempt for this exact setup. If reconciliation later cancels
+        it as missing/no-fill, Lab should not re-arm the same daily bar every
+        cycle.
+        """
+        if module not in {"laboratory", "daily"}:
+            return False
+        if not self._signal_matches_canonical_bar(metadata, match, module=module):
+            return False
+        outcome = metadata.get("execution_outcome") or {}
+        reconciliation = metadata.get("broker_reconciliation_resolution") or {}
+        outcome_reason = str(outcome.get("reason_code") or "")
+        reconciliation_source = str(reconciliation.get("source") or "")
+        if (
+            outcome_reason == "broker_order_missing_no_fill"
+            or reconciliation_source == "reconciliation_auto_cancel_missing_paper_order"
+        ):
+            return True
+        for trade in signal.trades:
+            trade_metadata = trade.metadata_json or {}
+            if (
+                trade.status == TradeStatus.CANCELLED
+                and str(trade.evidence_type or trade_metadata.get("evidence_type") or "")
+                == EvidenceType.IBKR_PAPER_ORDER.value
+                and (
+                    str(trade_metadata.get("close_reason") or "")
+                    == "broker_order_missing_no_position_no_open_order"
+                    or str(
+                        (trade_metadata.get("broker_reconciliation_resolution") or {}).get("source")
+                        or ""
+                    )
+                    == "reconciliation_auto_cancel_missing_paper_order"
+                )
+            ):
+                return True
+        return False
+
+    @staticmethod
+    def _duplicate_signal_skip_reason(signal: Signal) -> str:
+        metadata = signal.metadata_json or {}
+        outcome = metadata.get("execution_outcome") or {}
+        reconciliation = metadata.get("broker_reconciliation_resolution") or {}
+        if (
+            str(outcome.get("reason_code") or "") == "broker_order_missing_no_fill"
+            or str(reconciliation.get("source") or "")
+            == "reconciliation_auto_cancel_missing_paper_order"
+        ):
+            return "duplicate_signal_after_cancelled_broker_order"
+        return "duplicate_signal"
+
     @classmethod
     def _signal_matches_canonical_bar(
         cls,
