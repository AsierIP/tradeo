+def _status_value(value: Any) -> str:
+    return str(getattr(value, "value", value)).lower().strip()
+
+
+def _paper_order_missing_resolution(
+    trade: Trade,
+    *,
+    now: datetime,
+    settings: Settings,
+) -> dict[str, Any] | None:
+    metadata = trade.metadata_json or {}
+    if str(metadata.get("ibkr_mode") or settings.trading_mode) != "paper":
+        return None
+    if _status_value(trade.evidence_type) != EvidenceType.IBKR_PAPER_ORDER.value:
+        return None
+    if metadata.get("entry_fill_id_hash") or metadata.get("entry_broker_execution_hash"):
+        return None
+    if metadata.get("fill_provenance") == FillProvenance.BROKER_EXECUTION.value:
+        return None
+
+    observation = metadata.get("execution_observation") if isinstance(metadata, dict) else {}
+    submitted_at = _parse_ts((observation or {}).get("submitted_at") or metadata.get("submitted_at"))
+    age_seconds = (now - submitted_at).total_seconds() if submitted_at else None
+    grace_seconds = max(0, int(getattr(settings, "reconciliation_paper_order_visibility_grace_seconds", 90)))
+    if age_seconds is not None and age_seconds < grace_seconds:
+        return {
+            "action": "grace",
+            "age_seconds": round(age_seconds, 3),
+            "grace_seconds": grace_seconds,
+        }
+    if not bool(getattr(settings, "reconciliation_auto_cancel_missing_paper_orders", True)):
+        return None
+    return {
+        "action": "cancel",
+        "age_seconds": round(age_seconds, 3) if age_seconds is not None else None,
+        "grace_seconds": grace_seconds,
+    }
+
+
+def _cancel_missing_paper_order_trade(trade: Trade, *, now: datetime, detail: dict[str, Any]) -> None:
+    metadata = dict(trade.metadata_json or {})
+    metadata["close_reason"] = "broker_order_missing_no_position_no_open_order"
+    metadata["broker_reconciliation_resolution"] = {
+        "resolved_at": now.isoformat(),
+        "resolution": "cancelled_db_trade_no_broker_exposure",
+        "reason": "IBKR reports no position and no open orders for this paper order",
+        "source": "reconciliation_auto_cancel_missing_paper_order",
+        "divergence_candidate": detail,
+    }
+    metadata["execution_outcome"] = {
+        "status": "order_cancelled_no_fill",
+        "reason_code": "broker_order_missing_no_fill",
+        "reason": "IBKR no longer reports this paper order and no position exists",
+        "retryable": False,
+        "next_action": "do_not_retry_same_signal",
+        "updated_at": now.isoformat(),
+    }
+    trade.status = TradeStatus.CANCELLED
+    trade.closed_at = now
+    trade.exit_price = None
+    trade.pnl_usd = 0.0
+    trade.r_multiple = 0.0
+    trade.metadata_json = metadata
+    if trade.signal is not None:
+        signal_metadata = dict(trade.signal.metadata_json or {})
+        signal_metadata["execution_outcome"] = metadata["execution_outcome"]
+        signal_metadata["broker_reconciliation_resolution"] = metadata["broker_reconciliation_resolution"]
+        trade.signal.metadata_json = signal_metadata
+        trade.signal.status = SignalStatus.EXPIRED
+
