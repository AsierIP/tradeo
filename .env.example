# Tradeo local/VPN configuration
TRADEO_APP_NAME=Tradeo
TRADEO_ENVIRONMENT=local
TRADEO_DATABASE_URL=postgresql+psycopg://tradeo:tradeo@db:5432/tradeo
TRADEO_REDIS_URL=redis://redis:6379/0
TRADEO_SECRET_KEY=replace-with-a-long-random-string
TRADEO_ADMIN_USERNAME=admin
TRADEO_ADMIN_PASSWORD=replace-this-password
TRADEO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trading mode. Default must remain paper until the full validation gate is passed.
TRADEO_TRADING_MODE=paper
TRADEO_LIVE_TRADING_ENABLED=false
TRADEO_LIVE_TRADING_CONFIRMATION_VALUE=
TRADEO_KILL_SWITCH_ENABLED=false

# Account and risk policy
TRADEO_INITIAL_CAPITAL_USD=3000
TRADEO_RISK_PER_TRADE_PCT=0.01
TRADEO_DAILY_LOSS_LIMIT_PCT=0.02
TRADEO_MONTHLY_LOSS_LIMIT_PCT=0.08
TRADEO_MAX_OPEN_POSITIONS=4
TRADEO_MAX_GROSS_EXPOSURE_PCT=0.95
TRADEO_MAX_POSITION_VALUE_PCT=0.45
TRADEO_MIN_REWARD_RISK=2.5
TRADEO_PREFERRED_REWARD_RISK=3.0
TRADEO_PREMIUM_REWARD_RISK=4.0
TRADEO_ALLOW_LONGS=true
TRADEO_ALLOW_SHORTS=true
TRADEO_ALLOW_OPTIONS=false
TRADEO_ALLOW_MARGIN=false

# Market data and universe
TRADEO_MARKET_DATA_PROVIDER=yfinance
TRADEO_UNIVERSE_FILE=/app/data/universe_us_mid_small.csv
TRADEO_STRATEGY_CONFIG_FILE=/app/config/strategy_cup_v0.json
TRADEO_SCAN_PERIOD=2y
TRADEO_SCAN_INTERVAL=1d
TRADEO_SCAN_LIMIT_DEFAULT=50
TRADEO_MIN_AVG_DOLLAR_VOLUME=5000000
TRADEO_MIN_PRICE=2
TRADEO_MAX_ATR_PCT=0.14

# Optional OpenAI API supervisor. Disabled by default.
TRADEO_OPENAI_SUPERVISOR_ENABLED=false
TRADEO_OPENAI_API_KEY=
TRADEO_OPENAI_SUPERVISOR_MODEL=gpt-5.5-pro

# Interactive Brokers. TWS paper trading often uses 7497; confirm your local setup.
TRADEO_IBKR_HOST=host.docker.internal
TRADEO_IBKR_PORT=7497
TRADEO_IBKR_CLIENT_ID=17
TRADEO_IBKR_ACCOUNT=
TRADEO_IBKR_READONLY=true

# Scheduler
TRADEO_SCHEDULER_ENABLED=true
TRADEO_SCHEDULER_SCAN_MINUTES=15
TRADEO_SCHEDULER_REPORT_HOUR_UTC=22

# Novel pattern discovery laboratory. Runs locally/vectorized; no LLM tokens are spent on raw windows.
TRADEO_DISCOVERY_ENABLED=true
TRADEO_DISCOVERY_SCHEDULER_ENABLED=true
TRADEO_DISCOVERY_SCAN_MINUTES=90
TRADEO_DISCOVERY_PERIOD=5y
TRADEO_DISCOVERY_INTERVAL=1d
TRADEO_DISCOVERY_LIMIT_DEFAULT=80
TRADEO_DISCOVERY_WINDOW_SIZES=20,50,100,200
TRADEO_DISCOVERY_FORWARD_BARS=5,10,20
TRADEO_DISCOVERY_RR_LEVELS=1.5,2.0,2.5,3.0,4.0,5.0
TRADEO_DISCOVERY_STRIDE=3
TRADEO_DISCOVERY_MAX_TOTAL_WINDOWS=12000
TRADEO_DISCOVERY_MAX_WINDOWS_PER_SYMBOL=450
TRADEO_DISCOVERY_MIN_CLUSTER_SIZE=60
TRADEO_DISCOVERY_MAX_CLUSTERS_PER_WINDOW=12
TRADEO_DISCOVERY_MIN_SAMPLES=100
TRADEO_DISCOVERY_MIN_SYMBOLS=8
TRADEO_DISCOVERY_MIN_YEARS=2
TRADEO_DISCOVERY_MIN_PROFIT_FACTOR=1.8
TRADEO_DISCOVERY_MIN_EXPECTANCY_R=0.25
TRADEO_DISCOVERY_MIN_REWARD_RISK=2.5
TRADEO_DISCOVERY_CANDIDATE_REWARD_RISK=3.0
TRADEO_DISCOVERY_PREMIUM_REWARD_RISK=4.0
TRADEO_DISCOVERY_MAX_DRAWDOWN_R=12
TRADEO_UNVALIDATED_PATTERN_MIN_REWARD_RISK=4.0
TRADEO_DISCOVERY_MIN_STABILITY_SCORE=0.45
TRADEO_DISCOVERY_OUT_OF_SAMPLE_PCT=0.25
TRADEO_DISCOVERY_STORE_REJECTED=true
TRADEO_DISCOVERY_REPORT_TOP_N=20
TRADEO_DISCOVERY_MATCH_ENABLED=true
TRADEO_DISCOVERY_MATCH_SCAN_MINUTES=30
TRADEO_DISCOVERY_MATCH_SYMBOL_LIMIT=80
TRADEO_DISCOVERY_MATCH_MAX_PATTERNS=25
TRADEO_DISCOVERY_MATCH_SIMILARITY_THRESHOLD=0.45
TRADEO_DISCOVERY_MATCH_MAX_RESULTS=100
