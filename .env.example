# Tradeo local/VPN configuration
TRADEO_APP_NAME=Tradeo
TRADEO_ENVIRONMENT=local
TRADEO_DATABASE_URL=postgresql+psycopg://tradeo:tradeo@db:5432/tradeo
TRADEO_REDIS_URL=redis://redis:6379/0
TRADEO_SECRET_KEY=replace-with-a-long-random-string
TRADEO_ADMIN_USERNAME=admin
TRADEO_ADMIN_PASSWORD=replace-this-password
TRADEO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Docker published ports bind to localhost by default. Use a VPN/firewall-only
# address here only when the host is intentionally exposed.
TRADEO_BACKEND_BIND=127.0.0.1
TRADEO_FRONTEND_BIND=127.0.0.1

# Trading mode. Default must remain paper until the full validation gate is passed.
TRADEO_TRADING_MODE=paper
TRADEO_LIVE_TRADING_ENABLED=false
TRADEO_LIVE_TRADING_CONFIRMATION_VALUE=
TRADEO_KILL_SWITCH_ENABLED=false

# Account and risk policy
TRADEO_INITIAL_CAPITAL_USD=3000
TRADEO_RISK_PER_TRADE_PCT=0.01
TRADEO_DAILY_LOSS_LIMIT_PCT=0.02
TRADEO_MONTHLY_LOSS_LIMIT_PCT=0.08
TRADEO_MAX_OPEN_POSITIONS=4
TRADEO_MAX_GROSS_EXPOSURE_PCT=0.95
TRADEO_MAX_POSITION_VALUE_PCT=0.45
TRADEO_MAX_ADV_PARTICIPATION_PCT=0.005
TRADEO_MAX_OPEN_POSITIONS_PER_PATTERN_FAMILY=2
TRADEO_MIN_REWARD_RISK=4.0
TRADEO_PREFERRED_REWARD_RISK=4.0
TRADEO_PREMIUM_REWARD_RISK=4.0
TRADEO_ALLOW_LONGS=true
TRADEO_ALLOW_SHORTS=true
TRADEO_ALLOW_OPTIONS=false
TRADEO_ALLOW_MARGIN=false

# Market data and universe
TRADEO_MARKET_DATA_PROVIDER=ibkr
TRADEO_ALLOW_SYNTHETIC_MARKET_DATA=false
TRADEO_MARKET_DATA_CACHE_ENABLED=true
TRADEO_MARKET_DATA_CACHE_DIR=/app/data/ohlcv_cache
TRADEO_MARKET_DATA_ADJUSTED=true
TRADEO_MARKET_DATA_WHAT_TO_SHOW=ADJUSTED_LAST
# Incremental daily cache refresh (overlap-verified tail append; mismatch -> full refetch)
TRADEO_MARKET_DATA_INCREMENTAL_ENABLED=true
TRADEO_MARKET_DATA_INCREMENTAL_OVERLAP_BARS=5
TRADEO_MARKET_DATA_INCREMENTAL_MIN_GAP_DAYS=1
TRADEO_MARKET_DATA_INCREMENTAL_MAX_GAP_DAYS=45
# Intraday cache refresh (same overlap-verified append; gaps measured in bars/min, max in days)
TRADEO_MARKET_DATA_INCREMENTAL_INTRADAY_ENABLED=true
TRADEO_MARKET_DATA_INCREMENTAL_INTRADAY_MIN_GAP_BARS=2
TRADEO_MARKET_DATA_INCREMENTAL_INTRADAY_MAX_GAP_DAYS=5

# Intraday lane. Global flag stays false by default; every sub-mode is fail-closed.
TRADEO_INTRADAY_ENABLED=false
TRADEO_INTRADAY_SHADOW_ENABLED=false
TRADEO_INTRADAY_PAPER_ENABLED=false
TRADEO_INTRADAY_LIVE_ENABLED=false
TRADEO_INTRADAY_UNIVERSE_ENABLED=false
TRADEO_INTRADAY_DATA_SYNC_ENABLED=false
TRADEO_INTRADAY_RESEARCH_ENABLED=false
TRADEO_INTRADAY_CANDIDATE_SCAN_ENABLED=false
TRADEO_INTRADAY_OBSERVATION_CLOSER_ENABLED=false
TRADEO_INTRADAY_RISK_HEARTBEAT_ENABLED=true
TRADEO_INTRADAY_RECONCILIATION_ENABLED=true
TRADEO_INTRADAY_EOD_FLAT_ENABLED=true
TRADEO_INTRADAY_CALENDAR_ENABLED=false
TRADEO_INTRADAY_TIMEFRAMES=15m,5m
TRADEO_INTRADAY_EXECUTION_TIMEFRAME=1m
TRADEO_INTRADAY_SESSION_TIMEZONE=America/New_York
TRADEO_INTRADAY_NO_NEW_ENTRIES_AT=15:30
TRADEO_INTRADAY_CANCEL_ENTRIES_AT=15:45
TRADEO_INTRADAY_FORCE_FLAT_START_AT=15:50
TRADEO_INTRADAY_HARD_FLAT_DEADLINE_AT=15:55
TRADEO_INTRADAY_MIN_PRICE=3
TRADEO_INTRADAY_MIN_DOLLAR_VOLUME=1000000
TRADEO_INTRADAY_MAX_SPREAD_BPS=50
TRADEO_INTRADAY_MIN_RELATIVE_VOLUME=1.5
TRADEO_INTRADAY_RISK_PER_TRADE_PCT=0.0025
TRADEO_INTRADAY_DAILY_LOSS_LIMIT_PCT=0.005
TRADEO_INTRADAY_MAX_OPEN_POSITIONS=0
TRADEO_INTRADAY_MAX_TRADES_PER_DAY=0
TRADEO_INTRADAY_MAX_TRADES_PER_SYMBOL=0
TRADEO_INTRADAY_MIN_REWARD_RISK=4.0
TRADEO_INTRADAY_PACING_BUDGET_PER_10MIN=0
TRADEO_INTRADAY_DATA_SYNC_INTERVAL_SECONDS=300
TRADEO_INTRADAY_RESEARCH_INTERVAL_SECONDS=900
TRADEO_INTRADAY_RESEARCH_PERIOD=30d
TRADEO_INTRADAY_RESEARCH_LIMIT_DEFAULT=25
TRADEO_INTRADAY_RESEARCH_WINDOW_SIZES=20,50,100
TRADEO_INTRADAY_RESEARCH_FORWARD_BARS=3,6,12
TRADEO_INTRADAY_RESEARCH_STRIDE=1
TRADEO_INTRADAY_RESEARCH_MAX_TOTAL_WINDOWS=8000
TRADEO_INTRADAY_RESEARCH_MAX_WINDOWS_PER_SYMBOL=300
TRADEO_INTRADAY_RESEARCH_MIN_CLUSTER_SIZE=40
TRADEO_INTRADAY_RESEARCH_MAX_CLUSTERS_PER_WINDOW=8
TRADEO_INTRADAY_CANDIDATE_SCAN_INTERVAL_SECONDS=60
TRADEO_INTRADAY_OBSERVATION_CLOSER_INTERVAL_SECONDS=60
TRADEO_INTRADAY_RISK_HEARTBEAT_INTERVAL_SECONDS=60
TRADEO_INTRADAY_RECONCILIATION_INTERVAL_SECONDS=300
TRADEO_INTRADAY_JOB_JITTER_SECONDS=10
TRADEO_INTRADAY_UNIVERSE_PREMARKET_HOUR_UTC=12
TRADEO_INTRADAY_UNIVERSE_PREMARKET_MINUTE_UTC=45
TRADEO_INTRADAY_UNIVERSE_EARLY_HOUR_UTC=14
TRADEO_INTRADAY_UNIVERSE_EARLY_MINUTE_UTC=45
TRADEO_INTRADAY_EOD_FLAT_HOUR_UTC=20
TRADEO_INTRADAY_EOD_FLAT_MINUTE_UTC=55
TRADEO_INTRADAY_EOD_EMERGENCY_MARKET_ALLOWED=false

TRADEO_UNIVERSE_FILE=/app/data/universe_us_mid_small.csv
TRADEO_DAILY_UNIVERSE_FILE=/app/data/universe_us_mid_caps.csv
TRADEO_INTRADAY_UNIVERSE_FILE=/app/data/universe_us_small_caps.csv
TRADEO_UNIVERSE_SNAPSHOT_MONTHLY=true
TRADEO_UNIVERSE_SNAPSHOT_DIR=/app/data/universe_snapshots
TRADEO_UNIVERSE_POINT_IN_TIME_AVAILABLE=false
# Stays false until a licensed delisting/PIT membership source is wired
TRADEO_UNIVERSE_DELISTING_DATA_AVAILABLE=false
TRADEO_SURVIVORSHIP_CAP_STATE=lab_watchlist
# Benchmark market regime service (SPY SMA200 trend + trailing vol terciles)
TRADEO_MARKET_REGIME_BENCHMARK_SYMBOL=SPY
TRADEO_MARKET_REGIME_SMA_WINDOW=200
TRADEO_MARKET_REGIME_VOL_WINDOW=20
TRADEO_MARKET_REGIME_VOL_TERCILE_LOOKBACK=252
TRADEO_MARKET_REGIME_OUTCOME_MIN_SAMPLES=12
TRADEO_MARKET_REGIME_HARD_GATE_ENABLED=false
TRADEO_STRATEGY_CONFIG_FILE=/app/config/strategy_cup_v0.json
TRADEO_SCAN_PERIOD=2y
TRADEO_SCAN_INTERVAL=1d
TRADEO_SCAN_LIMIT_DEFAULT=50
TRADEO_MIN_AVG_DOLLAR_VOLUME=5000000
TRADEO_MIN_PRICE=2
TRADEO_MAX_ATR_PCT=0.14

# Filtro de calidad de datos OHLCV por simbolo antes de detectar patrones.
# Simbolos con barras sin volumen (halts), cierres congelados, huecos de
# calendario o saltos tipo split sin ajustar se saltan y quedan en AuditLog.
TRADEO_DATA_QUALITY_FILTER_ENABLED=true
TRADEO_DATA_QUALITY_MIN_BARS=60
TRADEO_DATA_QUALITY_MAX_ZERO_VOLUME_PCT=0.15
TRADEO_DATA_QUALITY_MAX_STALE_CLOSE_RUN=8
TRADEO_DATA_QUALITY_MAX_SINGLE_GAP_BUSINESS_DAYS=5
TRADEO_DATA_QUALITY_MAX_BAR_RETURN_RATIO=4.0

# Optional OpenAI API supervisor. Disabled by default.
TRADEO_OPENAI_SUPERVISOR_ENABLED=false
TRADEO_OPENAI_API_KEY=
TRADEO_OPENAI_SUPERVISOR_MODEL=gpt-5.5-pro

# Interactive Brokers.
# TWS paper: 7497; TWS live: 7496; IB Gateway paper: 4002; IB Gateway live: 4001.
# Keep readonly=true until paper execution is validated and live is explicitly armed.
TRADEO_IBKR_HOST=host.docker.internal
TRADEO_IBKR_PORT=7497
TRADEO_IBKR_CLIENT_ID=17
TRADEO_IBKR_ACCOUNT=
TRADEO_IBKR_READONLY=true
TRADEO_IBKR_CONNECT_TIMEOUT_SECONDS=8
TRADEO_IBKR_ORDER_TIMEOUT_SECONDS=20
TRADEO_IBKR_MAX_ORDER_VALUE_USD=1500
TRADEO_IBKR_ALLOW_MARKET_ORDERS=false
TRADEO_IBKR_ALLOWED_SYMBOLS=
TRADEO_IBKR_WHATIF_TIMEOUT_SECONDS=8

# Per-signal quote snapshot (spread real en el momento de la senal)
TRADEO_SIGNAL_SPREAD_SNAPSHOT_ENABLED=true
TRADEO_SIGNAL_SPREAD_SNAPSHOT_TIMEOUT_SECONDS=4

# Scheduler
TRADEO_SCHEDULER_ENABLED=true
TRADEO_SCHEDULER_SCAN_MINUTES=15
TRADEO_SCHEDULER_REPORT_HOUR_UTC=22
TRADEO_WATCHDOG_ENABLED=true
TRADEO_WATCHDOG_INTERVAL_MINUTES=5
TRADEO_WATCHDOG_STALE_DISCOVERY_MINUTES=30
TRADEO_WATCHDOG_CLOSE_STALE_DISCOVERY_RUNS=true
TRADEO_OPS_ALERTING_ENABLED=true
TRADEO_FALSE_MATCH_METRICS_JOB_ENABLED=true
TRADEO_FALSE_MATCH_METRICS_HOUR_UTC=23
TRADEO_FALSE_MATCH_METRICS_MINUTE_UTC=45
TRADEO_FALSE_MATCH_METRICS_HIGH_FPR_THRESHOLD=0.25

# Novel pattern discovery laboratory. Runs locally/vectorized; no LLM tokens are spent on raw windows.
TRADEO_DISCOVERY_ENABLED=true
TRADEO_DISCOVERY_SCHEDULER_ENABLED=true
# >=1440 = una sola pasada diaria post-cierre (cron 22:15 UTC por defecto).
# Repetir discovery intradía sobre la misma barra diaria solo infla N_trials (P0-8).
TRADEO_DISCOVERY_SCAN_MINUTES=1440
TRADEO_DISCOVERY_POST_CLOSE_HOUR_UTC=22
TRADEO_DISCOVERY_POST_CLOSE_MINUTE_UTC=15
TRADEO_DISCOVERY_PERIOD=5y
TRADEO_DISCOVERY_INTERVAL=1d
TRADEO_DISCOVERY_LIMIT_DEFAULT=80
TRADEO_DISCOVERY_WINDOW_SIZES=20,50,100,200
TRADEO_DISCOVERY_FORWARD_BARS=5,10,20
TRADEO_DISCOVERY_RR_LEVELS=2.5,4.0
TRADEO_SELF_IMPROVEMENT_MAX_TRIALS=80
TRADEO_SELF_IMPROVEMENT_MAX_PBO=0.10
TRADEO_SELF_IMPROVEMENT_MIN_PBO_BLOCKS=16
TRADEO_SELF_IMPROVEMENT_PLATEAU_PF_FRACTION=0.80
TRADEO_DISCOVERY_STRIDE=3
TRADEO_DISCOVERY_MAX_TOTAL_WINDOWS=12000
TRADEO_DISCOVERY_MAX_WINDOWS_PER_SYMBOL=450
TRADEO_DISCOVERY_MIN_CLUSTER_SIZE=60
TRADEO_DISCOVERY_MAX_CLUSTERS_PER_WINDOW=12
TRADEO_DISCOVERY_MIN_SAMPLES=100
# Gate sobre n_eff (pesos de unicidad tras dedup por simbolo), no sobre brutas (P0-1)
TRADEO_DISCOVERY_MIN_EFFECTIVE_SAMPLES=60
# BH-FDR a nivel de run sobre todos los clusters evaluados (P0-2)
TRADEO_DISCOVERY_FDR_Q=0.05
# DSR de familia (N_trials acumulado del registry) requerido para lab_candidate
TRADEO_DISCOVERY_MIN_DSR=0.95
TRADEO_DISCOVERY_MIN_SYMBOLS=8
TRADEO_DISCOVERY_MIN_YEARS=2
TRADEO_DISCOVERY_MIN_PROFIT_FACTOR=1.8
TRADEO_DISCOVERY_MIN_EXPECTANCY_R=0.25
TRADEO_DISCOVERY_MIN_REWARD_RISK=4.0
TRADEO_DISCOVERY_CANDIDATE_REWARD_RISK=4.0
TRADEO_DISCOVERY_PREMIUM_REWARD_RISK=4.0
TRADEO_DISCOVERY_MAX_DRAWDOWN_R=12
TRADEO_UNVALIDATED_PATTERN_MIN_REWARD_RISK=4.0
TRADEO_DISCOVERY_MIN_STABILITY_SCORE=0.45
TRADEO_DISCOVERY_OUT_OF_SAMPLE_PCT=0.25
TRADEO_DISCOVERY_STORE_REJECTED=true
TRADEO_DISCOVERY_REPORT_TOP_N=20
TRADEO_DISCOVERY_MATCH_ENABLED=true
TRADEO_DISCOVERY_MATCH_SCAN_MINUTES=30
TRADEO_DISCOVERY_MATCH_SYMBOL_LIMIT=80
TRADEO_DISCOVERY_MATCH_MAX_PATTERNS=25
# Suelo global; el criterio real es el tau por patron persistido en Research (P0-4)
TRADEO_DISCOVERY_MATCH_SIMILARITY_THRESHOLD=0.45
TRADEO_DISCOVERY_MATCH_PER_PATTERN_THRESHOLD=true
TRADEO_DISCOVERY_MATCH_TAU_PERCENTILE=92.5
# Nunca matchear contra la vela diaria viva: rompe la paridad Research-Lab (P0-3)
TRADEO_DISCOVERY_MATCH_COMPLETE_BARS_ONLY=true
TRADEO_DISCOVERY_MATCH_MAX_RESULTS=100

# Laboratory validates Research patterns in IBKR paper by default. Execution
# still requires entry/risk gates, paper mode, kill-switch off, live unarmed,
# and a non-live IBKR port.
TRADEO_LABORATORY_SCANNER_ENABLED=true
TRADEO_LABORATORY_SCAN_MINUTES=5
TRADEO_LABORATORY_SYMBOL_LIMIT=0
TRADEO_LABORATORY_MAX_PATTERNS=0
TRADEO_LABORATORY_MATCH_MAX_RESULTS=0
TRADEO_LABORATORY_SIMILARITY_THRESHOLD=0.45
TRADEO_LABORATORY_STORE_SIGNALS=true
TRADEO_LABORATORY_AUTO_SUBMIT_PAPER_ORDERS=true
TRADEO_LABORATORY_ALLOW_WATCHLIST_PAPER_ORDERS=false
TRADEO_LABORATORY_MARKET_HOURS_ONLY=true

# Execution loop hardening / Director gates.
TRADEO_DIRECTOR_MIN_EFF_TRADES=25
TRADEO_DIRECTOR_MIN_SYMBOLS=8
TRADEO_DIRECTOR_MIN_DAYS=10
TRADEO_DIRECTOR_MAX_MEDIAN_SLIPPAGE_R=0.10
TRADEO_RECONCILIATION_ENABLED=true
TRADEO_RECONCILIATION_INTERVAL_MINUTES=30
TRADEO_RECONCILIATION_AUTO_KILL_SWITCH=true
TRADEO_HEALTH_MONITOR_ENABLED=true
TRADEO_HEALTH_MONITOR_INTERVAL_MINUTES=60
TRADEO_HEALTH_MONITOR_MIN_TRADES=8
TRADEO_HEALTH_MONITOR_SHORTFALL_CUSUM_K=0.025
TRADEO_HEALTH_MONITOR_SHORTFALL_CUSUM_H=0.20

# FoxHunter remains closed by default. Live orders require this switch and the
# separate live-armed safety gate.
TRADEO_FOX_HUNTER_ENABLED=true
TRADEO_FOX_HUNTER_SCAN_MINUTES=1
TRADEO_FOX_HUNTER_SYMBOL_LIMIT=80
TRADEO_FOX_HUNTER_MAX_PATTERNS=25
TRADEO_FOX_HUNTER_SIMILARITY_THRESHOLD=0.50
TRADEO_FOX_HUNTER_STORE_SIGNALS=true
TRADEO_FOX_HUNTER_AUTO_SUBMIT_LIVE_ORDERS=false
TRADEO_FOX_HUNTER_MARKET_HOURS_ONLY=true
